- content_for :title do
  = t('jaap.jaaps')

- if policy(Jaap).create?
  .d-flex.justify-content-end.mb-2
    = link_to t('shared.add_new', name: t('jaap.jaaps')), new_jaap_path, class: 'btn btn-sm btn-primary'

.card
  .card-body.table-responsive
    %table.table.table-hover.pretty
      %thead
        %tr
          %th= t('jaap.province')
          %th= t('jaap.district')
          %th= t('jaap.commune')
          %th= t('shared.created_at')
          %th

      %tbody
        - @jaaps.each do |jaap|
          %tr
            %td= jaap.province_id
            %td= jaap.district_id
            %td= jaap.commune_id
            %td= jaap.created_at.strftime("%Y-%m-%d %H:%M")
            %td
              = link_to t('shared.view'), jaap_path(jaap), class: "btn btn-sm btn-info"
              = link_to t('shared.edit'), edit_jaap_path(jaap), class: "btn btn-sm btn-primary"

    - if @jaaps.empty?
      .text-center.py-4
        %p.text-muted= t('shared.no_data_found')

    = render "shared/footers/pagination" if @jaaps.any?
