= render "page_title", title: "#{t('scorecard.request_unlock')}: #{@scorecard.uuid}"

.card.shadow.mb-4
  .card-body
    %h5.mb-3
      = t('scorecard.unlock_request_form')
    
    %p.text-muted
      = t('scorecard.scorecard_uuid')
      = @scorecard.uuid
    
    %p.text-muted
      = t('scorecard.current_status')
      = t("scorecard.#{@scorecard.progress}")

    = render 'form', form_url: scorecard_unlock_requests_path(@scorecard.uuid), submit_label: t('shared.request'), form_method: :post
