.d-sm-flex.align-items-center.justify-content-end.mb-2
  .mt-3.mt-md-0.text-right.d-flex
    / Setting button (hidden on small screens, visible on lg+)
    - if policy(Scorecard).setting?
      %a.btn.btn-secondary.btn-sm.shadow-sm.mr-1.d-none.d-lg-inline-block{ href: setting_url }
        %i.fas.fa-wrench.fa-sm.text-white-50
        = t("sidebar.settings")

    / Download button (hidden on small screens, visible on lg+)
    - if policy(Scorecard).index?
      .mr-1.d-none.d-lg-inline-block
        %button.btn.btn-warning.btn-sm.shadow-sm.dropdown-toggle{type: "button", "aria-expanded" => "false", "aria-haspopup" => "true", "data-toggle" => "dropdown", type: "button"}

          %i.fas.fa-download
          = t('shared.download_excel')

        .dropdown-menu
          = render 'scorecards/index/download_items', item_class: nil

    / Add new button (hidden on small screens, visible on lg+)
    - if policy(Scorecard).create?
      %a.btn.btn-primary.btn-sm.shadow-sm.mr-1.d-none.d-lg-inline-block{ href: new_scorecard_path }
        %i.fas.fa-plus.fa-sm.text-white-50
        = t("scorecard.add_new")

    / More Options (shown when any relevant policy is true)
    - if policy(Scorecard).setting? || policy(Scorecard).index? || policy(Scorecard).create?
      .mr-1
        %button.btn.btn-sm{"aria-expanded" => "false", "aria-haspopup" => "true", "data-toggle" => "dropdown", :type => "button"}
          %i.fas.fa-ellipsis-v

        .dropdown-menu.dropdown-menu-right
          / Consolidated buttons for small screens (hidden on lg+)
          - if policy(Scorecard).setting?
            %a.btn.dropdown-item.d-block.d-lg-none{ href: setting_url }
              %i.fas.fa-wrench.drop-menu-icon
              %span= t("sidebar.settings")

          - if policy(Scorecard).index?
            = render 'scorecards/index/download_items', item_class: 'd-block d-lg-none'

          - if policy(Scorecard).create?
            %a.btn.dropdown-item.d-block.d-lg-none{ href: new_scorecard_path }
              %i.fas.fa-plus.drop-menu-icon
              %span= t("scorecard.add_new")

          / Divider between consolidated and regular items (small screens only, when there are regular items below)
          - if policy(Scorecard).create?
            .dropdown-divider.d-block.d-lg-none

          - if policy(Scorecard).create?
            %a.btn.dropdown-item{ href: new_scorecard_batch_path }
              %i.fas.fa-file-import.drop-menu-icon
              %span= t("scorecard.batch_import")

            %a.btn.dropdown-item{ href: scorecard_batches_path }
              %i.fas.fa-history.drop-menu-icon
              %span= t('scorecard.import_history')

            - if policy(RemovingScorecardBatch).create?
              %a.btn.dropdown-item{ href: new_removing_scorecard_path }
                %i.fas.fa-minus-circle.dropdown-item-icon
                %span= t('scorecard.remove_scorecard_from_excel')

              %a.btn.dropdown-item{ href: removing_scorecards_path }
                %i.fas.fa-eraser.dropdown-item-icon
                %span= t('scorecard_batch.removing_scorecard_history')
