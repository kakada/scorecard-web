= simple_form_for @form, url: scorecard_votes_path(@scorecard.token, locale: I18n.locale), html: { id: "voting-form", data: public_vote_form_data(@form, @scorecard) } do |f|
  .public-vote-container
    .container.my-5
      = f.hidden_field :device_submission_token
      = f.hidden_field :confirm_duplicate_submission, value: @form.confirm_duplicate_submission
      .row.justify-content-center.mb-3
        .col-md-10
          .card.shadow-sm
            = render 'votes/header', show_language: true

      -# Age
      .row.justify-content-center.mb-3
        .col-md-10
          .participant-profile-section.mt-2
            %h4.section-title= t('public_votes.participant_profile')

          .card.shadow-sm
            .card-body
              = f.input :age, as: :integer, input_html: { min: 1, max: 100, placeholder: "0" }, label: t('public_votes.age')

      -# Gender
      .row.justify-content-center.mb-3
        .col-md-10
          .card.shadow-sm
            .card-body
              %label.form-label.d-block
                = t('public_votes.gender')
                %abbr{title: "required"} *

              .gender-options.d-flex.gap-3
                - Participant::GENDERS.each do |gender|
                  %label.gender-option
                    = radio_button_tag 'public_vote_form[gender]', gender, f.object.gender == gender, required: true, class: "gender-radio"
                    .gender-box
                      .gender-icon
                        - if gender == 'female'
                          %i.fas.fa-venus
                        - elsif gender == 'male'
                          %i.fas.fa-mars
                        - else
                          %i.fas.fa-genderless
                      .gender-label= t("public_votes.gender_#{gender}")

              - if f.object.errors[:gender].present?
                %small.text-danger.mt-2= f.object.errors[:gender].join(", ")

      -# Profile Type Checkboxes
      .row.justify-content-center.mb-3
        .col-md-10
          .card.shadow-sm
            .card-body
              %label.form-label.d-block= t('public_votes.participant_type')
              .participant-type-options.d-flex.flex-wrap.gap-3
                %label.type-option
                  = check_box_tag 'public_vote_form[disability]', '1', f.object.disability, class: "type-checkbox"
                  .type-box
                    .type-icon
                      %i.fas.fa-wheelchair
                    .type-label= t('public_votes.disability')

                %label.type-option
                  = check_box_tag 'public_vote_form[minority]', '1', f.object.minority, class: "type-checkbox"
                  .type-box
                    .type-icon
                      %i.fas.fa-users
                    .type-label= t('public_votes.minority')

                %label.type-option
                  = check_box_tag 'public_vote_form[poor_card]', '1', f.object.poor_card, class: "type-checkbox"
                  .type-box
                    .type-icon
                      %i.fas.fa-id-card
                    .type-label= t('public_votes.poor_card')


      -# Voting Indicators
      - @form.indicators.each_with_index do |voting_indicator, index|
        .row.justify-content-center.mb-3
          .col-md-10
            - if index.zero?
              .voting-section.mt-2
                %h4.section-title.mb-4= t('public_votes.rate_indicators_title')

            .card.shadow-sm
              .card-body
                .indicator-item
                  .indicator-header.d-flex.align-items-start.mb-3
                    .indicator-info
                      %h5.indicator-name.mb-2
                        = "#{index + 1}. #{voting_indicator.indicator.name}"
                        %abbr{title: "required"} *

                  / ⭐ RATING SCALE INPUT (RADIO BUTTONS & STYLING)
                  .rating-options
                    .rating-buttons-group.d-flex.justify-content-between
                      - RatingScale.defaults.each do |scale|
                        %label.rating-option{ class: "score-#{scale[:value]}" }

                          = radio_button_tag( "public_vote_form[scores][#{voting_indicator.uuid}]", scale[:value], f.object.scores[voting_indicator.uuid] == scale[:value], required: true, class: "rating-radio")

                          .rating-box.d-flex.flex-column.align-items-center
                            .rating-emoji
                              = image_tag("#{scale[:code]}.png", class: "rating-emoji-img", alt: scale[:label])

                            .rating-label
                              %span.rating-score
                                = t("rating_scale.#{scale[:code]}")
                            .rating-label
                              %span.rating-score
                                = "(#{scale[:value]})"

                    - if @form.score_error?(voting_indicator)
                      %small.text-danger.mt-1
                        = @form.score_error_for(voting_indicator)
      -# Action button
      .row.justify-content-center.mb-3
        .col-md-10
          .mt-4
            = f.submit t('public_votes.submit'), class: "btn btn-primary btn-lg px-5"

          %div.text-center.mt-4
            %small= "#{t('public_votes.form_created_by')} \"#{t('public_votes.digital_community_scorecard')}\""
